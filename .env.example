# Webサーバー/cronの環境変数として設定してください（このファイルは自動読込されません）。
APP_URL=https://example.com/agrimore
APP_OPERATOR_NAME=運営者名
SUPPORT_EMAIL=support@example.com
APP_UNSUBSCRIBE_SECRET=32文字以上のランダムな秘密値
MAIL_TRANSPORT=mb_send_mail
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=AGRIMORE
MAIL_REPLY_TO=support@example.com
MAIL_BATCH_SIZE=50
MAIL_MAX_ATTEMPTS=3
# 現構成はmb_send_mailを利用します。SMTPライブラリ導入時にのみ以下を利用してください。
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
